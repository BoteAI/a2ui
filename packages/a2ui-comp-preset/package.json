{
  "name": "@boteai/a2ui-comp-preset",
  "version": "0.0.1",
  "description": "博特 A2UI 内置 Preset 组件集",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./registry": {
      "types": "./dist/esm/registry.d.ts",
      "import": "./dist/esm/registry.js",
      "default": "./dist/esm/registry.js"
    },
    "./schemas": {
      "types": "./dist/esm/presetSchemas.d.ts",
      "import": "./dist/esm/presetSchemas.js",
      "default": "./dist/esm/presetSchemas.js"
    }
  },
  "scripts": {
    "dev": "node scripts/build.mjs --watch",
    "build": "node scripts/build.mjs"
  },
  "keywords": [
    "a2ui",
    "preset",
    "components"
  ],
  "authors": [
    "wujian"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^17.x",
    "react-dom": "^17.x"
  },
  "dependencies": {
    "@boteai/a2ui-custom-kit": "^0.0.1",
    "antd": "4.24.14",
    "recharts": "2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "babel-plugin-import": "^1.13.8",
    "esbuild": "^0.21.5",
    "less": "^4.2.0",
    "react": "17.x",
    "react-dom": "17.x"
  },
  "gitHead": "87e7067353354821fb696aab6bb2e66c28a14dea"
}
