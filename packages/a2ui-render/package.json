{
  "name": "@boteai/a2ui-render",
  "version": "0.1.3",
  "description": "博特-A2UI 协议渲染引擎",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./preset-schemas": {
      "types": "./dist/esm/presetComp/presetSchemas.d.ts",
      "import": "./dist/esm/presetComp/presetSchemas.js",
      "default": "./dist/esm/presetComp/presetSchemas.js"
    },
    "./preset-registry": {
      "types": "./dist/esm/presetComp/registry.d.ts",
      "import": "./dist/esm/presetComp/registry.js",
      "default": "./dist/esm/presetComp/registry.js"
    }
  },
  "scripts": {
    "dev": "node ./scripts/embedShadowCss.js && father dev",
    "build": "node ./scripts/checkPresetArtifacts.js && node ./scripts/embedShadowCss.js && father build --no-clean",
    "build:lit-compat": "node ./scripts/buildLitCompat.js",
    "build:external": "node ./scripts/buildExternal.js",
    "build:deps": "father prebundle"
  },
  "keywords": [
    "a2ui",
    "render",
    "react"
  ],
  "authors": [
    "wujian"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "resolutions": {
    "@types/react": "17.x",
    "@types/react-dom": "17.x"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.9",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "antd": "4.24.14",
    "babel-loader": "^9.1.3",
    "babel-preset-react-app": "^10.0.1",
    "esbuild": "^0.28.0",
    "father": "^4.4.5",
    "stylelint": "^15.7.0"
  },
  "peerDependencies": {
    "react": "^17.x",
    "react-dom": "^17.x"
  },
  "dependencies": {
    "@a2ui/lit": "^0.9.3",
    "@a2ui/markdown-it": "^0.0.3",
    "@a2ui/web_core": "^0.9.2",
    "@babel/runtime": "^7.23.9",
    "zod": "^3.25.76"
  },
  "gitHead": "416aebcd896fe991e936910a95e2cd4a18f68766"
}
